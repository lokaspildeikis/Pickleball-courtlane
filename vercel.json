{
  "functions": {
    "api/**/*.ts": {
      "maxDuration": 15
    }
  },
  "rewrites": [
    {
      "source": "/sitemap.xml",
      "destination": "/api/sitemap"
    },
    {
      "source": "/((?!api).*)",
      "destination": "/index.html"
    }
  ],
  "crons": [
    {
      "path": "/api/cart-abandonment-cron",
      "schedule": "0 12 * * *"
    }
  ]
}
