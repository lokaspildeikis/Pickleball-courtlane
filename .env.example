# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# VITE_META_PIXEL_ID: Optional. Meta (Facebook) Pixel ID for ads and analytics.
# Create a pixel in Meta Events Manager and paste the ID here (build-time, public in bundle).
# VITE_META_PIXEL_ID="123456789012345"

# META_ACCESS_TOKEN: Meta Conversions API access token (server-side only).
# Do NOT prefix with VITE_ or it will be exposed in client bundle.
# META_ACCESS_TOKEN="your_meta_access_token"

# Coupon popup email sender settings (server-side on Vercel function /api/coupon-signup).
# Use your Hostinger mailbox SMTP credentials here.
# COUPON_SMTP_HOST="smtp.hostinger.com"
# COUPON_SMTP_PORT="465"
# COUPON_SMTP_USER="noreply@yourdomain.com"
# COUPON_SMTP_PASS="your-mailbox-password"
# COUPON_FROM_EMAIL="noreply@yourdomain.com"
# COUPON_FROM_NAME="Courtlane"
# COUPON_SUPPORT_EMAIL="hello@yourdomain.com"
# Optional: receive an internal email on every signup submission.
# COUPON_ADMIN_NOTIFY_EMAIL="you@yourdomain.com"
# NEW_CUSTOMER_COUPON_CODE="WELCOME5"
# SHOP_PUBLIC_URL="https://yourdomain.com"
# Optional: text shown in final abandoned-cart reminder email.
# ABANDONED_CART_FINAL_PERK="Free shipping"

# Abandoned cart scheduler + storage (required for automation).
# Create free Upstash Redis DB and paste REST credentials.
# UPSTASH_REDIS_REST_URL="https://your-upstash-endpoint.upstash.io"
# UPSTASH_REDIS_REST_TOKEN="your-upstash-rest-token"
# Optional: protects /api/cart-abandonment-cron
# CRON_SECRET="replace-with-random-secret"
# Optional testing overrides (minutes). Leave unset for production defaults:
# Email 1 = 30 min, Email 2 = 240 min, Email 3 = 1320 min (22h).
# ABANDONED_CART_EMAIL1_DELAY_MINUTES="2"
# ABANDONED_CART_EMAIL2_DELAY_MINUTES="5"
# ABANDONED_CART_EMAIL3_DELAY_MINUTES="10"

# Frontend coupon settings (public Vite vars).
# VITE_COUPON_SIGNUP_ENDPOINT="/api/coupon-signup"
# VITE_NEW_CUSTOMER_COUPON_CODE="WELCOME5"
